---
import Logo from "./Logo.astro";

const navLinks = [
  { href: "#tools", label: "Tools" },
  { href: "#roadmap", label: "Roadmap" },
  { href: "#team", label: "Team" },
];
---

<header class="site-header">
  <div class="container bar">
    <a class="brand" href="#top" aria-label="DrFed — back to top">
      <Logo size={34} eager={true} />
      <span class="wordmark">DrFed</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="actions">
      <a
        class="fedi"
        href="https://hackers.pub/@drfed"
        rel="me"
        title="Follow @drfed on the fediverse"
      >
        <span class="fedi-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Follow on the fediverse</span>
      </a>
      <a class="btn btn-primary btn-sm" href="#subscribe">Get updates</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(1.4) blur(12px);
    -webkit-backdrop-filter: saturate(1.4) blur(12px);
    border-bottom: 1px solid var(--line);
  }

  .bar {
    height: var(--header-h);
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink);
    text-decoration: none;
    margin-right: auto;
  }

  .brand:hover {
    text-decoration: none;
  }

  .wordmark {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: -0.02em;
  }

  .nav {
    display: flex;
    gap: 1.85rem;
  }

  .nav a {
    color: var(--ink-soft);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .nav a:hover {
    color: var(--accent-strong);
    text-decoration: none;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .fedi {
    display: inline-grid;
    place-items: center;
    width: 2.3rem;
    height: 2.3rem;
    border-radius: 999px;
    color: var(--ink-soft);
    border: 1px solid var(--line);
    transition: color 0.18s ease, border-color 0.18s ease,
      background-color 0.18s ease;
  }

  .fedi-icon {
    width: 1.1rem;
    height: 1.1rem;
    background-color: currentColor;
    -webkit-mask: url("/fediverse.svg") center / contain no-repeat;
    mask: url("/fediverse.svg") center / contain no-repeat;
  }

  .fedi:hover {
    color: var(--accent-strong);
    border-color: var(--accent);
    background: var(--surface-2);
  }

  .btn-sm {
    padding: 0.6em 1.1em;
    font-size: 0.9rem;
  }

  @media (max-width: 46rem) {
    .nav {
      display: none;
    }
    .bar {
      gap: 1rem;
    }
  }

  @media (max-width: 26rem) {
    .fedi {
      display: none;
    }
  }
</style>
