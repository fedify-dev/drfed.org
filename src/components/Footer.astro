---
import Logo from "./Logo.astro";
import nlnetBanner from "../assets/nlnet/banner.svg?url";
import ngi0CommonsFund from "../assets/nlnet/ngi0-commons-fund.svg?url";

const year = 2026;
---

<footer class="site-footer">
  <div class="container">
    <div class="top">
      <div class="brand">
        <a class="brand-link" href="#top" aria-label="DrFed — back to top">
          <Logo size={34} />
          <span class="wordmark">DrFed</span>
        </a>
        <p class="tagline">The ActivityPub debugging platform.</p>
      </div>

      <nav class="cols" aria-label="Footer">
        <div class="col">
          <h2>Project</h2>
          <ul>
            <li><a href="#tools">Tools</a></li>
            <li><a href="#roadmap">Roadmap</a></li>
            <li><a href="#open-source">Open source</a></li>
            <li><a href="#team">Team</a></li>
          </ul>
        </div>
        <div class="col">
          <h2>Connect</h2>
          <ul>
            <li>
              <a href="https://hackers.pub/@drfed" rel="me">Fediverse</a>
            </li>
            <li><a href="#subscribe">Newsletter</a></li>
            <li><a href="https://github.com/fedify-dev">GitHub</a></li>
            <li><a href="https://fedify.dev">Fedify</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="funding">
      <a
        class="chip"
        href="https://nlnet.nl/project/DrFed/"
        aria-label="DrFed on NLnet — funded by the NGI0 Commons Fund"
      >
        <img
          src={nlnetBanner}
          alt="NLnet Foundation"
          width="1086"
          height="415"
          class="logo-nlnet"
          loading="lazy"
        />
        <span class="divider" aria-hidden="true"></span>
        <img
          src={ngi0CommonsFund}
          alt="NGI0 Commons Fund"
          width="540"
          height="151"
          class="logo-ngi0"
          loading="lazy"
        />
      </a>
      <p class="ack">
        DrFed is funded through the <a href="https://nlnet.nl/project/DrFed/"
          >NGI0 Commons Fund</a
        >, established by <a href="https://nlnet.nl/">NLnet</a> with financial
        support from the European Commission’s Next Generation Internet
        programme.
      </p>
    </div>

    <div class="bottom">
      <p>
        © {year} The DrFed authors ·
        <a href="https://www.gnu.org/licenses/agpl-3.0.html" rel="license"
          ><code>AGPL-3.0</code></a
        >
      </p>
      <p class="made">Built by the Fedify team.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-tint);
    border-top: 1px solid var(--line);
    padding-block: clamp(3rem, 2rem + 3vw, 5rem);
    font-size: 0.95rem;
  }

  .top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2.5rem 3rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink);
    text-decoration: none;
  }

  .wordmark {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
  }

  .tagline {
    margin-top: 0.85rem;
    color: var(--ink-soft);
    max-width: 22rem;
  }

  .cols {
    display: flex;
    gap: clamp(2.5rem, 1rem + 6vw, 5rem);
  }

  .col h2 {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.95rem;
  }

  .col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .col a {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .col a:hover {
    color: var(--accent-strong);
  }

  /* Funding "certificate" chip — kept light in both colour schemes so the
     dark NLnet artwork stays legible. */
  .funding {
    margin-top: clamp(2.5rem, 2rem + 2vw, 4rem);
    padding-top: clamp(2rem, 1.5rem + 1.5vw, 3rem);
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2.25rem;
  }

  .chip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 1.5rem;
    border-radius: var(--radius);
    background: #fdfbfa;
    border: 1px solid #ecdfe2;
    box-shadow: 0 1px 2px rgba(43, 29, 34, 0.06),
      0 8px 24px rgba(43, 29, 34, 0.08);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .chip:hover {
    transform: translateY(-2px);
    box-shadow: 0 2px 4px rgba(43, 29, 34, 0.08),
      0 14px 34px rgba(43, 29, 34, 0.12);
  }

  .logo-nlnet {
    height: 2.4rem;
    width: auto;
  }

  .logo-ngi0 {
    height: 1.95rem;
    width: auto;
  }

  .divider {
    width: 1px;
    align-self: stretch;
    background: #ecdfe2;
  }

  .ack {
    flex: 1 1 18rem;
    color: var(--ink-soft);
    font-size: 0.88rem;
    line-height: 1.6;
    max-width: 36rem;
  }

  .bottom {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    color: var(--ink-faint);
    font-size: 0.85rem;
  }

  .bottom code {
    font-family: var(--font-mono);
    font-size: 0.95em;
  }

  @media (max-width: 30rem) {
    .chip {
      gap: 1rem;
      padding: 0.85rem 1.1rem;
    }
    .logo-nlnet {
      height: 1.9rem;
    }
    .logo-ngi0 {
      height: 1.55rem;
    }
  }
</style>
