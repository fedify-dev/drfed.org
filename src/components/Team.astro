---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import avatarChanHaeng from "../assets/team/2chanhaeng.png";
import avatarMinhee from "../assets/team/dahlia.jpg";
import avatarHyeonseo from "../assets/team/dodok8.png";
import avatarJiwon from "../assets/team/sij411.png";

interface Member {
  name: string;
  avatar: ImageMetadata;
  fediHandle: string;
  fediUrl: string;
  github: string;
  website?: string;
}

const team: Member[] = [
  {
    name: "ChanHaeng Lee",
    avatar: avatarChanHaeng,
    fediHandle: "@2chanhaeng@hackers.pub",
    fediUrl: "https://hackers.pub/@2chanhaeng",
    github: "2chanhaeng",
    website: "https://chomu.dev/",
  },
  {
    name: "Hong Minhee",
    avatar: avatarMinhee,
    fediHandle: "@hongminhee@hollo.social",
    fediUrl: "https://hollo.social/@hongminhee",
    github: "dahlia",
    website: "https://hongminhee.org/",
  },
  {
    name: "Hyeonseo Kim",
    avatar: avatarHyeonseo,
    fediHandle: "@gaebalgom@hackers.pub",
    fediUrl: "https://hackers.pub/@gaebalgom",
    github: "dodok8",
  },
  {
    name: "Jiwon Kwon",
    avatar: avatarJiwon,
    fediHandle: "@z9mb1@hackers.pub",
    fediUrl: "https://hackers.pub/@z9mb1",
    github: "sij411",
    website: "https://kwonjiwon.org/",
  },
];
---

<section class="team section" id="team">
  <div class="container">
    <div class="section-head scroll-reveal">
      <span class="eyebrow">The team</span>
      <h2>Built by the people behind Fedify.</h2>
      <p class="lede">
        DrFed is made by the maintainers of <a href="https://fedify.dev"
          >Fedify</a
        >, the TypeScript ActivityPub framework used by Ghost and others. The
        same experience building and debugging federated software informs how
        DrFed is designed.
      </p>
    </div>

    <ul class="grid">
      {
        team.map((member) => (
          <li class="member scroll-reveal">
            <Image
              class="avatar"
              src={member.avatar}
              alt={`${member.name}`}
              width={200}
              height={200}
              loading="lazy"
            />
            <h3>{member.name}</h3>
            <a class="fedi" href={member.fediUrl} rel="me">
              {member.fediHandle}
            </a>
            <div class="links">
              <a
                href={`https://github.com/${member.github}`}
                aria-label={`${member.name} on GitHub`}
              >
                <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                  <path
                    fill="currentColor"
                    d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
                  ></path>
                </svg>
                <span class="visually-hidden">GitHub</span>
              </a>
              {
                member.website && (
                  <a href={member.website} aria-label={`${member.name}'s website`}>
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      focusable="false"
                    >
                      <circle cx="12" cy="12" r="10" />
                      <path d="M2 12h20" />
                      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </svg>
                    <span class="visually-hidden">Website</span>
                  </a>
                )
              }
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: clamp(1.25rem, 1rem + 1vw, 2rem);
  }

  .member {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .avatar {
    width: 5.25rem;
    height: 5.25rem;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--line-strong);
    background: var(--surface-2);
    margin-bottom: 1.1rem;
  }

  .member h3 {
    font-size: 1.18rem;
    margin-bottom: 0.45rem;
  }

  .fedi {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--accent-strong);
    word-break: break-word;
    line-height: 1.4;
  }

  .links {
    margin-top: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    color: var(--ink-faint);
    transition: color 0.18s ease, transform 0.18s ease;
  }

  .links svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .links a:hover {
    color: var(--ink);
    transform: translateY(-1px);
  }
</style>
