---
import Logo from "./Logo.astro";
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow load-reveal" style="--delay: 0s">
        ActivityPub debugging platform
      </p>
      <h1 class="load-reveal" style="--delay: 0.05s">
        Debugging tools for the fediverse.
      </h1>
      <p class="lede load-reveal" style="--delay: 0.12s">
        DrFed is a web-based platform for developing and debugging ActivityPub
        implementations&mdash;inspecting objects and activities, and tracing where
        federation fails. It is built by the team behind <strong>Fedify</strong>.
      </p>
      <div class="cta load-reveal" style="--delay: 0.2s">
        <a class="btn btn-primary" href="#subscribe">Subscribe for updates</a>
        <a class="btn btn-ghost" href="https://hackers.pub/@drfed" rel="me"
          >Follow <span class="handle">@drfed</span></a
        >
      </div>
      <p class="status load-reveal" style="--delay: 0.28s">
        <span class="dot" aria-hidden="true"></span>
        In active development; not yet released.
      </p>
    </div>

    <div class="hero-art load-reveal" style="--delay: 0.1s" aria-hidden="true">
      <div class="halo"></div>
      <Logo size={300} class="mark" eager={true} alt="" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: clip;
    padding-block: clamp(3rem, 2rem + 7vw, 7rem);
  }

  .hero-bg {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 130%;
    z-index: -1;
    background: radial-gradient(
      52% 48% at 82% 20%,
      var(--accent-tint) 0%,
      transparent 64%
    );
    opacity: 0.5;
    filter: blur(10px);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    min-height: min(72vh, 40rem);
  }

  .hero-copy {
    max-width: 36rem;
  }

  h1 {
    margin-top: 1.1rem;
  }

  .lede {
    margin-top: 1.6rem;
  }

  .cta {
    margin-top: 2.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .handle {
    font-family: var(--font-mono);
    font-size: 0.92em;
    font-weight: 500;
  }

  .status {
    margin-top: 1.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--ink-soft);
  }

  .dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .hero-art {
    justify-self: center;
    position: relative;
    display: grid;
    place-items: center;
  }

  .hero-art .mark {
    width: clamp(11rem, 26vw, 19rem);
    height: auto;
    filter: drop-shadow(0 14px 30px rgba(38, 33, 31, 0.12));
  }

  .halo {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 112%;
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--accent-soft) 26%, transparent) 0%,
      transparent 70%
    );
    z-index: -1;
  }

  @media (max-width: 54rem) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1rem;
      min-height: 0;
    }
    .hero-copy {
      max-width: 40rem;
      margin-inline: auto;
      order: 2;
    }
    .hero-art {
      order: 1;
      margin-bottom: 0.5rem;
    }
    .hero-art .mark {
      width: clamp(8rem, 38vw, 12rem);
    }
    .cta,
    .status {
      justify-content: center;
    }
    .eyebrow {
      margin-inline: auto;
    }
  }
</style>
